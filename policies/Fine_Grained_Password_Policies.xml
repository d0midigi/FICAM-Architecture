<?xml version="1.0" encoding="utf-8"?>
<FineGrainedPasswordPolicy xmlns="http://microsoft.com">
  <!-- 
    Target Object: Password Settings Object (PSO) 
    Compliance Mapping: NIST SP 800-53 Rev. 5 (IA-5 / IA-5(1)) - Authenticator Management 
    Application: Apply exclusively to non-smart card accounts (e.g., Service Accounts, Break-Glass Admins)
  -->
  <Name>FICAM-Fallback-High-Security-PSO</Name>
  
  <!-- Precedence: Lower values take priority if multiple PSOs apply to an object -->
  <Precedence>10</Precedence>
  
  <!-- Reversible Encryption: Must be disabled to prevent plain-text equivalent storage (NIST Baseline) -->
  <ReversibleEncryptionEnabled>false</ReversibleEncryptionEnabled>
  
  <!-- Password History: Remembers the last 24 passwords to prevent immediate cycling -->
  <PasswordHistoryCount>24</PasswordHistoryCount>
  
  <!-- Complexity Requirements: Enforces uppercase, lowercase, digits, and special characters -->
  <PasswordComplexityEnabled>true</PasswordComplexityEnabled>
  
  <!-- Minimum Password Length: Set to 15 characters minimum for privileged fallback accounts -->
  <MinPasswordLength>15</MinPasswordLength>
  
  <!-- Minimum Password Age: Restricts users from changing a password more than once a day (1:00:00:00) -->
  <MinPasswordAge>1.00:00:00</MinPasswordAge>
  
  <!-- Maximum Password Age: Forces a periodic cryptographic reset cycle every 60 days (60:00:00:00) -->
  <MaxPasswordAge>60.00:00:00</MaxPasswordAge>
  
  <!-- Account Lockout Threshold: Locks the account after 3 consecutive failed logon attempts -->
  <LockoutThreshold>3</LockoutThreshold>
  
  <!-- Lockout Observation Window: Tracks failed attempts within a rolling 30-minute window (00:30:00) -->
  <LockoutObservationWindow>00:30:00</LockoutObservationWindow>
  
  <!-- Lockout Duration: Account remains safely locked for 30 minutes before automatic reset (00:30:00) -->
  <LockoutDuration>00:30:00</LockoutDuration>
</FineGrainedPasswordPolicy>


<!-- To deploy this in your domain environment, an administrator can import t or map these exact parameters using the Active Directory Administrative Center (ADAC) under the System -> Password Settings Container. -->